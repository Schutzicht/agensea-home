---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout title="Logo Concepten">
  <Navbar />
  
  <main class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <header class="mb-16">
        <h1 class="text-4xl font-display font-bold text-dark mb-4">Logo & Icoon Concepten</h1>
        <p class="text-lg text-dark/60">Experimenten om een herkenbaar beeldmerk te smeden uit de letters van Agensea.</p>
      </header>

      <div class="grid gap-20">
        
        <!-- Concept 1: De Geometrische 'a' -->
        <section class="reveal">
          <div class="flex flex-col md:flex-row gap-10 items-start">
            <div class="flex-1">
              <span class="inline-block px-3 py-1 bg-indigo/10 text-indigo text-[10px] font-bold uppercase tracking-widest rounded-full mb-4">Concept 01</span>
              <h2 class="text-2xl font-bold mb-4">De Digitale 'a'</h2>
              <p class="text-dark/70 mb-6 underline decoration-indigo/30 underline-offset-4">
                Hierbij maken we van de eerste letter een strak, geometrisch icoon. De bovenkant is een perfecte curve, terwijl de 'staart' van de a een scherpe 45-graden hoek maakt (als een pixel of een pijl die omhoog wijst).
              </p>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-dark rounded-xl flex items-center justify-center text-white font-bold">
                  <!-- Favicon preview -->
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 4C7.58172 4 4 7.58172 4 12V20H8V12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12V20H20V12C20 7.58172 16.4183 4 12 4Z" fill="currentColor"/>
                    <path d="M16 16H8V20H16V16Z" fill="currentColor"/>
                  </svg>
                </div>
                <div class="w-12 h-12 bg-indigo rounded-xl flex items-center justify-center text-white font-bold">
                   <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 4C7.58172 4 4 7.58172 4 12V20H8V12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12V20H20V12C20 7.58172 16.4183 4 12 4Z" fill="currentColor"/>
                    <path d="M16 16H8V20H16V16Z" fill="currentColor"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-8 bg-white rounded-3xl border border-dark/5 shadow-sm flex-1 flex items-center justify-center">
              <div class="text-4xl font-display font-bold tracking-tight">
                <span class="text-indigo">
                  <svg class="inline-block w-[0.8em] h-[0.8em] mb-1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 4C7.58172 4 4 7.58172 4 12V20H8V12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12V20H20V12C20 7.58172 16.4183 4 12 4Z" fill="currentColor"/>
                    <path d="M16 16H8V20H16V16Z" fill="currentColor"/>
                  </svg>
                </span>gensea.
              </div>
            </div>
          </div>
        </section>

        <!-- Concept 2: De 'Infinite Sea' S -->
        <section class="reveal">
          <div class="flex flex-col md:flex-row-reverse gap-10 items-start">
            <div class="flex-1">
              <span class="inline-block px-3 py-1 bg-indigo/10 text-indigo text-[10px] font-bold uppercase tracking-widest rounded-full mb-4">Concept 02</span>
              <h2 class="text-2xl font-bold mb-4">De Wave-S</h2>
              <p class="text-dark/70 mb-6">
                De 'S' vormt de brug tussen Agency en Sea. We maken hier een custom icoon van dat bestaat uit twee vloeiende golven die samen de letter S vormen. Dit symboliseert beweging, flow en adaptiviteit.
              </p>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-indigo/10 rounded-xl flex items-center justify-center text-indigo font-bold border border-indigo/20">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17 7C17 7 15 5 12 5C9 5 7 7 7 10C7 13 17 11 17 14C17 17 15 19 12 19C9 19 7 17 7 17" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12 5C14 5 16 6 17 7.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.3"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-8 bg-dark rounded-3xl border border-white/5 shadow-2xl flex-1 flex items-center justify-center">
              <div class="text-4xl font-display font-bold tracking-tight text-white">
                agen<span class="text-indigo">
                  <svg class="inline-block w-[0.8em] h-[0.8em] mb-1" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17 7C17 7 15 5 12 5C9 5 7 7 7 10C7 13 17 11 17 14C17 17 15 19 12 19C9 19 7 17 7 17" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>ea.
              </div>
            </div>
          </div>
        </section>

        <!-- Concept 3: De 'ea' Ligatuur -->
        <section class="reveal">
          <div class="flex flex-col md:flex-row gap-10 items-start">
            <div class="flex-1">
              <span class="inline-block px-3 py-1 bg-indigo/10 text-indigo text-[10px] font-bold uppercase tracking-widest rounded-full mb-4">Concept 03</span>
              <h2 class="text-2xl font-bold mb-4">De Sea-Ligatuur (ea)</h2>
              <p class="text-dark/70 mb-6">
                We versmelten de 'e' en de 'a' tot één symbool. De horizontale lijn van de 'e' loopt over in de curve van de 'a'. Dit geeft een heel high-end, custom look die perfect is voor een minimalistisch icoon.
              </p>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-dark font-bold border border-dark/10">
                   <svg width="28" height="24" viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 12C4 8.68629 6.68629 6 10 6H12M12 6C15.3137 6 18 8.68629 18 12M12 6V18M18 12C18 15.3137 15.3137 18 12 18H10M18 12V20H24V12C24 8.68629 21.3137 6 18 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-8 bg-cream rounded-3xl border border-dark/5 shadow-inner flex-1 flex items-center justify-center">
              <div class="text-4xl font-display font-bold tracking-tight">
                agens<span class="text-indigo">
                  <svg class="inline-block w-[1.2em] h-[0.8em] mb-1" viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 12C4 8.68629 6.68629 6 10 6H12M12 6C15.3137 6 18 8.68629 18 12M12 6V18M18 12C18 15.3137 15.3137 18 12 18H10M18 12V20H24V12C24 8.68629 21.3137 6 18 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  </svg>
                </span>.
              </div>
            </div>
          </div>
        </section>

      </div>

      <div class="mt-32 p-10 bg-indigo rounded-[40px] text-white text-center">
        <h3 class="text-2xl font-bold mb-4">Welke spreekt je het meest aan?</h3>
        <p class="opacity-80 mb-8 max-w-md mx-auto text-sm">Zodra we een favoriet hebben, kan ik dit karakter in het hoofdlogo definitief verfijnen en als los SVG-bestand voor je exporteren voor favicon/socials.</p>
        <div class="flex flex-wrap justify-center gap-4">
           <!-- Directe links naar de testvariaties zouden hier kunnen, maar we wachten op feedback -->
        </div>
      </div>
    </div>
  </main>

  <style>
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</Layout>
