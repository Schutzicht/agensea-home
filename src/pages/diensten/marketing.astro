---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-28 md:pt-36 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-16 md:mb-28">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-dark mb-5">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-base md:text-lg text-text-secondary leading-relaxed mb-8 max-w-xl">
              Of je nu meer bereik, naamsbekendheid of concrete leads wilt: wij zetten de juiste campagnes op, op de juiste kanalen, voor de juiste doelgroep. Datagedreven en altijd transparant.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#werkwijze" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>

          </div>
        </div>
        <!-- Right: Ad Platform Cycler -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-white relative">
            <div class="h-9 bg-[#f5f3ef] flex items-center px-4 gap-3 border-b border-warm-grey/15">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-[#FF5F57]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#FEBC2E]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#28C840]"></div>
              </div>
              <span id="adPlatformLabel" class="ml-2 text-[9px] font-bold uppercase tracking-wider text-text-secondary/50 transition-opacity duration-300">Google Search</span>
              <div class="ml-auto flex gap-1.5">
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/40" data-index="0"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="1"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="2"></div>
                <div class="ad-dot w-1.5 h-1.5 rounded-full bg-dark/15" data-index="3"></div>
              </div>
            </div>

            <div id="adContainer" class="h-[290px] relative overflow-hidden">

              <!-- Google Search Ad -->
              <div class="ad-layout active" data-platform="Google Search" id="ad1">
                <div class="p-5 space-y-3">
                  <div class="ad-el">
                    <div class="flex items-center gap-2 mb-2">
                      <div class="w-5 h-5 rounded-full bg-indigo/10 flex items-center justify-center">
                        <svg class="w-3 h-3" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/></svg>
                      </div>
                      <div class="w-20 h-2 bg-warm-grey/20 rounded-sm"></div>
                    </div>
                    <div class="ml-7 bg-cream rounded-xl p-3 border border-warm-grey/15">
                      <span class="text-[8px] font-bold text-dark/30 uppercase tracking-wider">Gesponsord</span>
                    </div>
                  </div>
                  <div class="ad-el ml-7 bg-cream rounded-xl p-4 border border-warm-grey/15">
                    <div class="text-[10px] text-emerald-600 font-mono mb-1">www.jouwbedrijf.nl</div>
                    <div class="w-4/5 h-3 bg-[#1a0dab]/70 rounded-sm mb-2"></div>
                    <div class="w-full h-1.5 bg-warm-grey/20 rounded-sm mb-1"></div>
                    <div class="w-3/4 h-1.5 bg-warm-grey/15 rounded-sm mb-3"></div>
                    <div class="flex gap-2">
                      <div class="text-[8px] font-bold text-indigo bg-indigo/10 px-2 py-1 rounded">Bel nu</div>
                      <div class="text-[8px] font-bold text-indigo bg-indigo/10 px-2 py-1 rounded">Locatie</div>
                    </div>
                  </div>
                  <div class="ad-el ml-7 space-y-2 opacity-40">
                    <div class="w-2/3 h-2.5 bg-[#1a0dab]/30 rounded-sm"></div>
                    <div class="w-full h-1.5 bg-warm-grey/15 rounded-sm"></div>
                  </div>
                  <div class="ad-el ml-7 space-y-2 opacity-25">
                    <div class="w-1/2 h-2.5 bg-[#1a0dab]/25 rounded-sm"></div>
                    <div class="w-3/4 h-1.5 bg-warm-grey/10 rounded-sm"></div>
                  </div>
                </div>
              </div>

              <!-- Instagram Feed Ad -->
              <div class="ad-layout" data-platform="Instagram" id="ad2">
                <div class="p-5 space-y-3">
                  <div class="ad-el flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-amber-400 via-pink-500 to-violet-600"></div>
                      <div>
                        <div class="w-20 h-2 bg-dark/70 rounded-sm mb-1"></div>
                        <div class="text-[8px] text-text-secondary/50">Gesponsord</div>
                      </div>
                    </div>
                    <div class="flex gap-0.5"><div class="w-1 h-1 rounded-full bg-dark/30"></div><div class="w-1 h-1 rounded-full bg-dark/30"></div><div class="w-1 h-1 rounded-full bg-dark/30"></div></div>
                  </div>
                  <div class="ad-el w-full h-32 bg-gradient-to-br from-indigo/10 via-violet/15 to-pink-100 rounded-xl"></div>
                  <div class="ad-el flex items-center gap-4">
                    <svg class="w-5 h-5 text-dark/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    <svg class="w-5 h-5 text-dark/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <svg class="w-5 h-5 text-dark/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                  </div>
                  <div class="ad-el">
                    <div class="w-16 h-2 bg-dark/50 rounded-sm mb-1.5"></div>
                    <div class="w-full h-1.5 bg-warm-grey/20 rounded-sm mb-1"></div>
                    <div class="w-2/3 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                  </div>
                </div>
              </div>

              <!-- LinkedIn Sponsored Post -->
              <div class="ad-layout" data-platform="LinkedIn" id="ad3">
                <div class="p-5 space-y-3">
                  <div class="ad-el flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-[#0A66C2]/10 flex items-center justify-center shrink-0">
                      <div class="w-6 h-6 rounded bg-[#0A66C2]/30"></div>
                    </div>
                    <div class="flex-1">
                      <div class="w-24 h-2.5 bg-dark/60 rounded-sm mb-1"></div>
                      <div class="text-[8px] text-text-secondary/50">12.340 volgers · Gesponsord</div>
                    </div>
                  </div>
                  <div class="ad-el space-y-1.5">
                    <div class="w-full h-2 bg-warm-grey/25 rounded-sm"></div>
                    <div class="w-full h-2 bg-warm-grey/20 rounded-sm"></div>
                    <div class="w-2/3 h-2 bg-warm-grey/15 rounded-sm"></div>
                  </div>
                  <div class="ad-el w-full h-24 bg-gradient-to-r from-[#0A66C2]/10 to-[#0A66C2]/5 rounded-xl border border-[#0A66C2]/10 flex items-end p-3">
                    <div class="flex items-center justify-between w-full">
                      <div>
                        <div class="w-20 h-2 bg-dark/40 rounded-sm mb-1"></div>
                        <div class="w-14 h-1.5 bg-warm-grey/20 rounded-sm"></div>
                      </div>
                      <div class="px-3 py-1.5 border border-[#0A66C2]/40 rounded-full">
                        <div class="w-12 h-2 bg-[#0A66C2]/40 rounded-sm"></div>
                      </div>
                    </div>
                  </div>
                  <div class="ad-el flex items-center gap-6">
                    <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-full bg-[#0A66C2]/20"></div><div class="w-6 h-1.5 bg-warm-grey/20 rounded-sm"></div></div>
                    <div class="w-8 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                    <div class="w-10 h-1.5 bg-warm-grey/15 rounded-sm"></div>
                  </div>
                </div>
              </div>

              <!-- Google Display Banner -->
              <div class="ad-layout" data-platform="Display Banner" id="ad4">
                <div class="p-5 space-y-4">
                  <div class="ad-el text-center">
                    <span class="text-[8px] font-bold text-text-secondary/30 uppercase tracking-widest">Advertentie</span>
                  </div>
                  <div class="ad-el w-full h-40 bg-gradient-to-br from-dark via-dark/95 to-indigo/80 rounded-2xl p-5 flex flex-col justify-between relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-indigo/20 rounded-full blur-2xl"></div>
                    <div>
                      <div class="w-20 h-3 bg-white/80 rounded-sm mb-2"></div>
                      <div class="w-32 h-2.5 bg-white/50 rounded-sm mb-1"></div>
                      <div class="w-24 h-2 bg-white/30 rounded-sm"></div>
                    </div>
                    <div class="flex items-center justify-between">
                      <div class="w-8 h-8 bg-white/10 rounded-lg"></div>
                      <div class="px-4 py-2 bg-indigo rounded-lg"><div class="w-12 h-2 bg-white/80 rounded-sm"></div></div>
                    </div>
                  </div>
                  <div class="ad-el flex items-center justify-between px-1">
                    <div class="text-[8px] text-text-secondary/30">320 x 250</div>
                    <div class="flex gap-1"><div class="w-3 h-3 rounded bg-warm-grey/15"></div><div class="w-3 h-3 rounded bg-warm-grey/15"></div></div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Werkwijze: Clean Typographic Strips -->
    <section id="werkwijze" class="relative z-10 py-24 md:py-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="reveal mb-16 md:mb-24">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Werkwijze
          </span>
          <h2 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] text-dark max-w-3xl">
            Vier stappen naar <span class="text-indigo">meetbaar resultaat.</span>
          </h2>
        </div>
      </div>

      <div class="border-t border-warm-grey">
        
        <!-- Stap 1 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">01</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Kennismaking</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Vrijblijvend</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                We duiken in je business, ontleden samen de doelgroep en leveren een transparant voorstel op maat. Inclusief platformkeuze, budgetindicatie en een helder kostenplaatje. Geen verrassingen.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 2 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-violet to-violet/20 bg-clip-text text-transparent leading-none select-none">02</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Strategie op maat</h3>
              <span class="inline-block mt-2 text-xs font-bold text-violet bg-violet/10 px-3 py-1 rounded-full uppercase tracking-widest">Na akkoord</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Van grove schets naar scherp plan. We verfijnen de doelgroep, verdelen het budget over de juiste kanalen en zetten KPI's en meetpunten klaar. Zodat elke euro die je investeert meetbaar is.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 3 -->
        <div class="reveal group block border-b border-warm-grey">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-indigo to-indigo/20 bg-clip-text text-transparent leading-none select-none">03</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Lancering</h3>
              <span class="inline-block mt-2 text-xs font-bold text-text-secondary uppercase tracking-widest">Go live</span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Accounts gekoppeld, pixels geplaatst, advertenties vormgegeven, doelgroepen ingesteld. Alles staat klaar. Dan drukken we samen op de knop en gaan jouw campagnes live.
              </p>
            </div>
          </div>
        </div>

        <!-- Stap 4 -->
        <div class="reveal group block border-b border-warm-grey bg-gradient-to-r from-indigo/[0.04] to-transparent">
          <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-6 md:gap-12 items-start">
            <div class="md:col-span-2">
              <span class="font-display text-7xl md:text-8xl font-bold bg-gradient-to-b from-emerald-500 to-emerald-500/20 bg-clip-text text-transparent leading-none select-none">04</span>
            </div>
            <div class="md:col-span-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-dark">Optimalisatie</h3>
              <span class="inline-flex items-center gap-2 mt-2 text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                </span>
                Doorlopend
              </span>
            </div>
            <div class="md:col-span-6">
              <p class="text-text-secondary text-base md:text-lg leading-relaxed">
                Hier stopt het niet. We monitoren dagelijks, testen nieuwe varianten, sturen budgetten bij en rapporteren transparant. Zo halen we steeds meer uit elke euro die je investeert.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<style>
  .ad-layout {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  .ad-layout.active {
    opacity: 1;
    pointer-events: auto;
  }
  .ad-layout .ad-el {
    opacity: 0;
    transform: translateY(8px);
  }
  .ad-layout.active .ad-el {
    animation: adBuild 0.5s ease-out forwards;
  }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(1),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(1) { animation-delay: 0.1s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(2),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(2) { animation-delay: 0.35s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(3),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(3) { animation-delay: 0.6s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(4),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(4) { animation-delay: 0.85s; }
  .ad-layout.active .space-y-3 > .ad-el:nth-child(5),
  .ad-layout.active .space-y-4 > .ad-el:nth-child(5) { animation-delay: 1.05s; }
  .ad-layout.fading .ad-el {
    animation: adFade 0.35s ease-in forwards !important;
  }
  @keyframes adBuild {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes adFade {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-4px); }
  }
</style>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }

  // Ad platform cycler
  const adLayouts = document.querySelectorAll('.ad-layout');
  const adLabel = document.getElementById('adPlatformLabel');
  const adDots = document.querySelectorAll('.ad-dot');
  let adCurrent = 0;
  const AD_DISPLAY = 4000;
  const AD_FADE = 450;

  function updateDots(index) {
    adDots.forEach((dot, i) => {
      if (i === index) {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/40 transition-all duration-300';
      } else {
        dot.className = 'ad-dot w-1.5 h-1.5 rounded-full bg-dark/15 transition-all duration-300';
      }
    });
  }

  function showAd(index) {
    const layout = adLayouts[index];
    if (adLabel && layout.dataset.platform) {
      adLabel.style.opacity = '0';
      setTimeout(() => {
        adLabel.textContent = layout.dataset.platform;
        adLabel.style.opacity = '1';
      }, 180);
    }
    updateDots(index);
    layout.querySelectorAll('.ad-el').forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight;
      el.style.animation = '';
    });
    layout.classList.remove('fading');
    layout.classList.add('active');
  }

  function hideAd(index) {
    const layout = adLayouts[index];
    layout.classList.add('fading');
    setTimeout(() => {
      layout.classList.remove('active', 'fading');
    }, AD_FADE);
  }

  function cycleAd() {
    hideAd(adCurrent);
    setTimeout(() => {
      adCurrent = (adCurrent + 1) % adLayouts.length;
      showAd(adCurrent);
    }, AD_FADE);
  }

  showAd(0);
  setInterval(cycleAd, AD_DISPLAY + AD_FADE);
</script>
