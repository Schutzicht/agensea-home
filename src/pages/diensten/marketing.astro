---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Cases from '../../components/Cases.astro';
import CTA from '../../components/CTA.astro';
---

<Layout title="Online Marketing & Groei | Agensea">
  <Navbar />
  
  <main class="bg-cream min-h-screen pt-32 md:pt-48 pb-20 overflow-hidden relative">
    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="mesh-blob w-[600px] h-[600px] bg-indigo/10 top-[-10%] right-[-10%] blur-[120px]"></div>
      <div class="mesh-blob w-[500px] h-[500px] bg-violet/10 bottom-[10%] left-[-10%] blur-[100px]"></div>
    </div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10 mb-24 md:mb-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Content -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
              <span class="w-8 h-[2px] bg-indigo"></span>
              Onze diensten
            </span>
            <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-dark mb-8">
              Meer klanten en <span class="text-indigo">online groei.</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl">
              Je wilt beter gevonden worden en structureel meer aanvragen of verkopen realiseren. Met datagedreven campagnes en slimme SEO zorgen we dat jouw ideale klant je direct weet te vinden.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/contact" class="magnetic-btn px-8 mx-0 py-4 bg-dark text-white rounded-xl font-medium hover:bg-indigo transition-colors duration-300">
                Laten we sparren
              </a>
              <a href="#aanpak" class="px-8 py-4 border border-warm-grey/50 rounded-xl font-medium text-dark hover:border-indigo transition-all duration-300">
                Ontdek onze aanpak
              </a>
            </div>
          </div>
        </div>
        <!-- Right Graphic area: Bar Chart -->
        <div class="lg:col-span-5 reveal" style="transition-delay: 200ms;">
          <div class="w-full aspect-[4/5] bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-white relative flex flex-col justify-end p-8">
             <div class="absolute top-8 left-8">
               <span class="text-xs font-bold uppercase tracking-widest text-text-secondary/50">Groei Conversies (Q3)</span>
               <div class="text-4xl font-display font-bold text-dark mt-1">+142%</div>
             </div>
             
             <div class="flex items-end gap-4 h-48 w-full">
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-1/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-2/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-cream border border-warm-grey/30 rounded-t-xl h-3/4 relative group hover:bg-indigo/10 transition-colors"></div>
               <div class="w-1/4 bg-indigo shadow-[0_0_20px_rgba(79,70,229,0.3)] rounded-t-xl h-full relative">
                 <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-dark text-white text-xs font-bold py-1 px-3 rounded shadow-lg">Nu</div>
               </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Details Section -->
    <section id="aanpak" class="py-24 bg-white relative z-10 w-full rounded-[3rem] shadow-sm mb-24 md:mb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <h2 class="font-display text-4xl leading-tight font-bold mb-16 text-center max-w-2xl mx-auto">Giswerk eruit, <span class="text-indigo">meetbaar resultaat</span> erin.</h2>
        
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <!-- Feature 1 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Adverteren (SEA)</h3>
            <p class="text-text-secondary leading-relaxed">We plaatsen jouw bedrijf strak bovenaan in Google en op relevante socials, precies op het moment dat een potentiële klant naar je oplossingen zoekt.</p>
          </div>
          <!-- Feature 2 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Organisch (SEO)</h3>
            <p class="text-text-secondary leading-relaxed">Een lange-termijn strategie om zonder advertentiekosten structureel nieuwe bezoekers en autoriteit op te bouwen.</p>
          </div>
          <!-- Feature 3 -->
          <div class="p-8 rounded-3xl bg-cream border border-warm-grey/30 hover:border-indigo/30 transition-colors">
            <h3 class="font-bold text-xl mb-4">Campagne Optimalisatie</h3>
            <p class="text-text-secondary leading-relaxed">Geen "set and forget". We sturen pro-actief op data, meten de Return On Investment (ROI) doorlopend en scherpen wekelijks aan voor het hoogste rendement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Werkwijze: 4-Stappen Proces -->
    <section class="py-24 md:py-40 px-6 lg:px-10 relative z-10">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16 md:mb-24 reveal">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-indigo uppercase tracking-[0.2em] mb-6">
            <span class="w-8 h-[2px] bg-indigo"></span>
            Onze werkwijze
            <span class="w-8 h-[2px] bg-indigo"></span>
          </span>
          <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight max-w-2xl mx-auto">
            Van kennismaking tot <span class="text-indigo">doorlopend resultaat.</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
          <!-- Connecting line (desktop) -->
          <div class="hidden lg:block absolute top-16 left-[12.5%] right-[12.5%] h-[2px] bg-gradient-to-r from-emerald-400 via-amber-400 via-60% to-indigo z-0"></div>

          <!-- Step 1 -->
          <div class="reveal relative" style="transition-delay: 0ms;">
            <div class="relative z-10 flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-2xl bg-emerald-50 border-2 border-emerald-400 flex items-center justify-center mb-6">
                <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div class="bg-white rounded-3xl border border-warm-grey/30 p-6 md:p-8 hover:border-emerald-300 transition-colors w-full">
                <h3 class="font-display font-bold text-lg mb-3">Kennismaking & voorstel</h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">We analyseren de situatie en doen een eerste voorstel.</p>
                <ul class="text-left text-sm text-text-secondary space-y-2">
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Doelstellingen bepalen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Analyse product/dienst en doelgroep</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Indicatieve doelgroepselectie</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Voorstel platformkeuze (Google, Meta, LinkedIn, etc.)</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Indicatie advertentiebudget</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Vaststellen maandelijkse beheerkosten</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Vaststellen setup kosten</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="reveal relative" style="transition-delay: 100ms;">
            <div class="relative z-10 flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-2xl bg-amber-50 border-2 border-amber-400 flex items-center justify-center mb-6">
                <svg class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </div>
              <div class="bg-white rounded-3xl border border-warm-grey/30 p-6 md:p-8 hover:border-amber-300 transition-colors w-full">
                <h3 class="font-display font-bold text-lg mb-1">Strategische uitwerking</h3>
                <p class="text-xs text-indigo font-medium mb-3">(na akkoord)</p>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">Nu gaan we van indicatie + definitief plan.</p>
                <p class="text-dark text-sm font-bold mb-2">In deze fase doen wij o.a.:</p>
                <ul class="text-left text-sm text-text-secondary space-y-2">
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Exacte doelgroepbepaling en grootte</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Verfijning platformstrategie</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Definitieve budgetverdeling</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Campagnestructuur bepalen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Meetplan en conversietracking</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-amber-400 mt-2 shrink-0"></span>Planning en KPI-afstemming</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="reveal relative" style="transition-delay: 200ms;">
            <div class="relative z-10 flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-2xl bg-indigo/10 border-2 border-indigo/50 flex items-center justify-center mb-6">
                <svg class="w-5 h-5 text-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
              <div class="bg-white rounded-3xl border border-warm-grey/30 p-6 md:p-8 hover:border-indigo/30 transition-colors w-full">
                <h3 class="font-display font-bold text-lg mb-3">Campagne-setup & lancering</h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">We bouwen en activeren de campagnes.</p>
                <p class="text-dark text-sm font-bold mb-2">Dit omvat o.a.:</p>
                <ul class="text-left text-sm text-text-secondary space-y-2">
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Advertentieaccounts inrichten of koppelen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Tracking & conversiemetingen instellen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Pixels/tags implementeren</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Advertenties en visuals afstemmen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Doelgroepen instellen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-indigo mt-2 shrink-0"></span>Campagnes live zetten</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="reveal relative" style="transition-delay: 300ms;">
            <div class="relative z-10 flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-2xl bg-emerald-50 border-2 border-emerald-400 flex items-center justify-center mb-6">
                <svg class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
              </div>
              <div class="bg-white rounded-3xl border border-warm-grey/30 p-6 md:p-8 hover:border-emerald-300 transition-colors w-full">
                <h3 class="font-display font-bold text-lg mb-3">Optimalisatie & rapportage</h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">Doorlopend verbeteren voor maximaal resultaat.</p>
                <p class="text-dark text-sm font-bold mb-2">Dit omvat o.a.:</p>
                <ul class="text-left text-sm text-text-secondary space-y-2">
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Monitoren prestaties</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Optimaliseren doelgroepen en advertenties</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Budget bijsturen indien nodig</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Nieuwe varianten testen</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Periodieke rapportage en evaluatie</li>
                  <li class="flex items-start gap-2"><span class="w-1 h-1 rounded-full bg-emerald-400 mt-2 shrink-0"></span>Strategische bijsturing</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Cases />
    <CTA />
  </main>
  
  <Footer />
</Layout>

<script>
  const observeElements = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  };
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeElements);
  } else {
    observeElements();
  }
</script>
